# Gold rate microservice configuration
# Copy this file to .env and edit values.

# Port the service listens on (default 6000)
PORT=6000

# Gold API key (optional depending on your provider plan)
GOLD_API_KEY=

# Gold API base URL
GOLD_API_URL=https://api.gold-api.com

# Optional: override USD -> LKR conversion factor.
# Leave empty to fetch live FX rate.
USD_TO_LKR=

# Cache TTL in milliseconds (0 = no cache, always fetch live)
CACHE_TTL_MS=0
