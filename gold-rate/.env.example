# Gold rate microservice configuration
# Copy this file to .env and edit values.

# Port the service listens on (default 6000)
PORT=6000

# API key for external gold price source (e.g. GoldAPI.io, Metals-API)
# If you use GoldAPI.io, set GOLD_API_KEY and leave GOLD_API_URL empty.
GOLD_API_KEY=

# Optional: alternate gold API endpoint. If unset, service will use GoldAPI defaults.
# Example: https://www.goldapi.io/api/XAU/USD
GOLD_API_URL=

# Optional: URL to scrape Devi Jewellers gold rate from (must return HTML)
# We try to parse numeric gold rates (24K, 22K, 20K) from the HTML.
DEVI_GOLD_URL=

# Optional: override USD -> LKR conversion factor.
# If not set, the service will fetch the latest USD->LKR rate from exchangerate.host
USD_TO_LKR=
