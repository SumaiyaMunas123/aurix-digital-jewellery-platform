# Gold rate microservice configuration

# API key for external gold price source (e.g. GoldAPI.io)
GOLD_API_KEY=goldapi-5ge021smmu85r31-io
GOLD_API_URL=https://api.gold-api.com

# Optional: URL to scrape Devi Jewellers gold rate from
# DEVI_GOLD_URL=https://www.deviwatches.com/

# Optional: override USD -> LKR conversion factor.
USD_TO_LKR=

# Cache TTL in milliseconds (default 300000 = 5 minutes)
CACHE_TTL_MS=0

# Port the service listens on (default 6000)
PORT=6001